#N canvas 699 398 746 366 12;
#X obj 61 28 inlet;
#X obj 61 287 outlet;
#X obj 177 287 outlet;
#X obj 177 214 float \$2;
#X obj 61 214 symbol \$1;
#X obj 61 156 trigger bang bang;
#X text 252 207 \$1 = 第一个参数 \; \$2 = 第二个参数//;
#X text 239 110 通过在抽象内对象使用美元符号（\$1 \, \$2等），外部的参数可以被加载到 抽象内（注意：不要与在消息框内部使用美元符号的情况相混淆！）, f 60;
#X text 396 169 每当你看到一个程序内包含带有 \$1、，\$2 等参数的对象时，说明它是作为抽象来设计的， 需要被加载到一个父程序中，以便从中接收并 加载参数//。, f 37;
#X text 239 64 这是一个抽象的示例，功能非常简单，仅仅只是加载父程序中抽象的连带 参数并输出//;
#X text 285 272 请注意，这些参数会显示在程序窗口顶部的标题栏中，紧挨着抽 象的名称，并且被包裹在括号里。//, f 53;
#X text 690 110 *如果你已经忘了，这是信息框内使用 美元符号的例子//, f 30;
#X msg 753 161 symbol Alice;
#X symbolatom 753 223 5 0 0 0 - - - 12;
#X msg 753 192 symbol \$1;
#X connect 0 0 5 0;
#X connect 3 0 2 0;
#X connect 4 0 1 0;
#X connect 5 0 4 0;
#X connect 5 1 3 0;
#X connect 12 0 14 0;
#X connect 14 0 13 0;
#X coords 0 0 1 1 100 100 0;
